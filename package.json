{
  "name": "@proxysoul/soulforge",
  "version": "2.20.19",
  "description": "Graph-powered code intelligence — multi-agent coding with codebase-aware AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/proxysoul/soulforge.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "module": "src/boot.tsx",
  "type": "module",
  "license": "BUSL-1.1",
  "author": "proxySoul",
  "bin": {
    "soulforge": "./scripts/launcher.mjs",
    "sf": "./scripts/launcher.mjs",
    "soulforge-remote": "./dist/soulforge-remote.sh"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "dist",
    "scripts/postinstall.mjs",
    "scripts/launcher.mjs",
    "THIRD_PARTY_LICENSES.md"
  ],
  "scripts": {
    "dev": "bun run src/boot.tsx",
    "build": "bun scripts/build.ts",
    "build:no-compiler": "bun build src/boot.tsx --outdir dist --target bun --external react-devtools-core --entry-naming \"[dir]/index.[ext]\"",
    "build:binary": "bun build src/boot.tsx --compile --external react-devtools-core --outfile bin/soulforge",
    "bundle": "bash scripts/bundle.sh arm64 darwin",
    "bundle:x64": "bash scripts/bundle.sh x64 darwin",
    "bundle:linux": "bash scripts/bundle.sh x64 linux",
    "bundle:linux-arm64": "bash scripts/bundle.sh arm64 linux",
    "build:binary:windows": "bun scripts/build.ts --compile --target=bun-windows-x64 --outfile=bin/soulforge-windows-x64.exe",
    "bundle:windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-windows.ps1 -Arch x64",
    "bundle:windows-arm64": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/bundle-windows.ps1 -Arch arm64",
    "installer:windows": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Arch x64",
    "installer:windows-arm64": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build-installer.ps1 -Arch arm64",
    "selfextract:windows": "bun build --compile --target=bun-windows-x64 --minify --outfile=bin/soulforge-installer-x64.exe scripts/installer-cli.mjs",
    "selfextract:windows-arm64": "bun build --compile --target=bun-windows-arm64 --minify --outfile=bin/soulforge-installer-arm64.exe scripts/installer-cli.mjs",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage",
    "test:coverage:html": "bun run test:coverage && genhtml coverage/lcov.info --output-directory coverage/html --dark-mode && open coverage/html/index.html",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run build",
    "release": "bun run build && npm publish",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:dry": "bash scripts/release.sh patch --dry-run",
    "postinstall": "bun scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@babel/core": "8.0.1",
    "@biomejs/biome": "2.5.0",
    "@types/babel__core": "7.20.5",
    "@types/bun": "1.3.14",
    "@types/linkify-it": "5.0.0",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "1.3.14",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.119",
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/deepseek": "^2.0.39",
    "@ai-sdk/fireworks": "^2.0.57",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/mcp": "^1.0.52",
    "@ai-sdk/mistral": "^3.0.40",
    "@ai-sdk/openai": "^3.0.73",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@ai-sdk/xai": "^3.0.96",
    "@anthropic-ai/sdk": "0.105.0",
    "@clack/prompts": "^1.6.0",
    "@llmgateway/ai-sdk-provider": "3.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "0.6.0",
    "@openrouter/ai-sdk-provider": "2.9.1",
    "@opentui/react": "0.4.1",
    "ai": "^6.0.208",
    "ghostty-opentui": "1.5.0",
    "ignore": "^7.0.5",
    "isbinaryfile": "6.0.0",
    "jsonrepair": "^3.14.0",
    "linkedom": "0.18.12",
    "linkify-it": "5.0.1",
    "marked": "18.0.5",
    "neovim": "5.4.0",
    "react": "19.2.7",
    "shiki": "4.2.0",
    "strip-ansi": "7.2.0",
    "tree-sitter-wasms": "0.1.13",
    "ts-morph": "28.0.0",
    "undici": "^8.5.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "web-tree-sitter": "0.25.10",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "optionalDependencies": {
    "@opentui/core-darwin-arm64": "0.4.1",
    "@opentui/core-darwin-x64": "0.4.1",
    "@opentui/core-linux-arm64": "0.4.1",
    "@opentui/core-linux-x64": "0.4.1",
    "@opentui/core-win32-arm64": "0.4.1",
    "@opentui/core-win32-x64": "0.4.1"
  }
}
