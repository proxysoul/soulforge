{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "SoulForge",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#9B30FF",
    "light": "#B366FF",
    "dark": "#9B30FF"
  },
  "rounded": "sharp",
  "font": {
    "headings": {
      "family": "JetBrains Mono",
      "weight": 700
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "installation",
              "windows",
              "quickstart",
                "faq"
              ]
          },
          {
            "group": "Sponsors",
            "pages": [
              "sponsors"
            ]
          },
          {
            "group": "Recipes",
            "pages": [
              "recipes/rename-refactor",
              "recipes/test-and-commit",
              "recipes/task-router",
              "recipes/model-fallback",
              "recipes/plan-mode",
              "recipes/headless"
            ]
          },
          {
            "group": "Providers",
            "pages": [
              "providers/overview",
              "providers/custom",
              "providers/copilot"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/hearth",
              "tools/memory",
              "tools/editor",
              "tools/lsp",
              "tools/project",
              "tools/mcp",
              "tools/ast-edit",
              "tools/skills",
              "tools/sessions",
              "tools/hooks",
              "tools/checkpoints",
              "tools/themes",
              "tools/terminals"
            ]
          },
          {
            "group": "How it works",
            "pages": [
              "concepts/architecture",
              "concepts/repo-map",
              "concepts/intelligence",
              "concepts/compound-tools",
              "concepts/cost-tracking",
              "concepts/model-events",
              "agents/dispatch",
              "agents/steering",
              "agents/cross-tab",
              "context/compaction",
              "context/provider-options",
              "context/prompt-system"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/commands",
              "reference/configuration",
              "troubleshooting"
            ]
          }
          ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/proxysoul/soulforge",
          "icon": "github"
        },
        {
          "anchor": "Blog",
          "href": "https://proxysoul.com/blog/soulforge",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/proxysoul/soulforge"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "/installation"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor",
      "mcp"
    ]
  },
  "redirects": [
    { "source": "/tools/headless", "destination": "/recipes/headless" },
    { "source": "/docs/copilot-provider", "destination": "/providers/copilot" },
    { "source": "/docs/hearth", "destination": "/tools/hearth" }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/proxysoul/soulforge",
      "linkedin": "https://linkedin.com/in/pouiiro",
      "x": "https://x.com/proxysoul"
    }
  }
}
